<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Home</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
</head>

<body class="bg-light">

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow-lg p-5 text-center" style="max-width: 500px; width:100%;">

            <h1 class="text-primary mb-3">Home Page</h1>

            <p class="text-muted mb-4">
                Welcome to Google OAuth Authentication
            </p>

            <% if (user) { %>

                <h5 class="mb-4">
                    Welcome,
                    <span class="text-success">
                        <%= user.name %>
                    </span>
                </h5>

                <a href="/profile" class="btn btn-outline-success btn-lg w-100">
                    Go To Profile
                </a>

                <% } else { %>

                    <a href="/auth/login" class="btn btn-outline-primary btn-lg w-100">
                        Go To Login
                    </a>

                    <% } %>

        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>

</body>

</html>